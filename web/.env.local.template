# Environment variables for local development
# Copy this file to .env.local and replace with actual values

VITE_FUNCTIONS_KEY=your_azure_functions_key_here
VITE_API_BASE_URL=https://your-azure-functions-url.azurewebsites.net/

# Optional: override host for corporation playerstats (spike — FastAPI on VM).
# When set, /api/corporations/playerstats is fetched from this host instead of
# the default Azure Functions API. Leave unset to keep using Azure Functions.
# Example: VITE_VM_API_BASE=http://20.82.3.63:8001
VITE_VM_API_BASE=
